{
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../dist"
  },
  "identifier": "com.sovereign-os.app",
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "title": "Sovereign Engine OS",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "W50cnVzdGVkIGNvbW1lbnQ6IGNyeXB0IHNlY3JldCBrZXkKdWluSHB1YmxpYyBrZXkKZGVmYXVsdAo=",
      "endpoints": [
        "https://github.com/fourmeme21/sovereign-os-ui/releases/latest/download/latest.json"
      ]
    }
  }
}
